<Page x:Class="ToutieTrader.UI.Pages.StrategyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}"
      Title="Strategy">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28" MaxWidth="640">

            <TextBlock Text="STRATEGY"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource MutedBrush}"
                       Margin="0,0,0,24"/>

            <!-- ── Sélection ───────────────────────────────────────────────── -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="2"
                    Padding="24,20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="SÉLECTION"
                               FontSize="10"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,12"/>

                    <ComboBox x:Name="CmbStrategy"
                              SelectionChanged="CmbStrategy_SelectionChanged"
                              HorizontalAlignment="Stretch"/>

                    <TextBlock x:Name="TxtStrategyLocked"
                               Text="⚠  Impossible de changer de Strategy pendant un live."
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="11" Margin="0,8,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- ── Settings dynamiques de la Strategy ────────────────────── -->
            <Border x:Name="PanelSettings"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="2"
                    Padding="24,20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="OPTIONS"
                               FontSize="10"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Rempli dynamiquement depuis code-behind -->
                    <StackPanel x:Name="SettingsContainer"/>
                </StackPanel>
            </Border>

            <!-- Aucune stratégie chargée -->
            <TextBlock x:Name="TxtNoStrategy"
                       Text="Aucune Strategy trouvée dans le dossier /Strategies/."
                       Foreground="{StaticResource MutedBrush}"
                       FontSize="12"
                       Visibility="Collapsed"
                       Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
