<Window x:Class="ToutieTrader.UI.Windows.TradePopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Détail du Trade"
        Width="1100" Height="720"
        MinWidth="700" MinHeight="500"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

      <!-- ── Colonne gauche : infos texte ─────────────────────────────────── -->
      <Grid Grid.Column="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── En-tête ──────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock x:Name="TxtSymbol"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,12,0"/>
            <Border x:Name="BadgeDir"
                    CornerRadius="2" Padding="8,2"
                    VerticalAlignment="Center">
                <TextBlock x:Name="TxtDirection"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>
            <TextBlock x:Name="TxtProfitLoss"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Grille prix ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="2"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0 : labels -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="ENTRÉE" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="SORTIE" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="SL"     FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="TP"     FontSize="10" Foreground="{StaticResource MutedBrush}"/>

                <!-- Row 2 : valeurs prix -->
                <TextBlock x:Name="TxtEntry"  Grid.Row="2" Grid.Column="0" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtExit"   Grid.Row="2" Grid.Column="1" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtSl"     Grid.Row="2" Grid.Column="2" Foreground="{StaticResource DangerBrush}"/>
                <TextBlock x:Name="TxtTp"     Grid.Row="2" Grid.Column="3" Foreground="{StaticResource SuccessBrush}"/>

                <!-- Séparateur -->
                <Rectangle Grid.Row="4" Grid.ColumnSpan="4"
                           Height="1" Fill="{StaticResource BorderBrush}"/>

                <!-- Row 4 : labels dates -->
                <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="DATE ENTRÉE" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2"
                           Text="DATE SORTIE" FontSize="10" Foreground="{StaticResource MutedBrush}"/>

                <!-- Row 6 : valeurs dates -->
                <TextBlock x:Name="TxtEntryTime" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" FontSize="11"/>
                <TextBlock x:Name="TxtExitTime"  Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" FontSize="11"/>
            </Grid>
        </Border>

        <!-- ── Conditions remplies ───────────────────────────────────────────── -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="2"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="CONDITIONS À L'ENTRÉE"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           Margin="0,0,0,10"/>
                <ItemsControl x:Name="ListConditions">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontSize="12"
                                       Margin="0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="RAISON SORTIE"
                           FontSize="10" Foreground="{StaticResource MutedBrush}"
                           Margin="0,12,0,4"/>
                <TextBlock x:Name="TxtExitReason" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ── Bouton fermer ─────────────────────────────────────────────────── -->
        <Button Grid.Row="6"
                Content="Fermer"
                Style="{StaticResource BtnSecondary}"
                HorizontalAlignment="Right"
                Click="BtnClose_Click"/>
      </Grid>

      <!-- ── Colonne droite : chart WebView2 ────────────────────────────────── -->
      <Border Grid.Column="2"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="2"
              Background="#0D0D0F">
          <wv2:WebView2 x:Name="Chart"/>
      </Border>
    </Grid>
</Window>
