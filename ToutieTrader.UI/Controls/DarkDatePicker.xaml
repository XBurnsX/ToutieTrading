<UserControl x:Class="ToutieTrader.UI.Controls.DarkDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Champ date cliquable -->
        <Border x:Name="BdMain"
                Background="#1A1A1E" BorderBrush="#222228" BorderThickness="1"
                CornerRadius="2" Cursor="Hand" MouseLeftButtonUp="BdMain_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtDate" Grid.Column="0"
                           Foreground="#E8002D" FontSize="12" FontFamily="Segoe UI"
                           Padding="8,5" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="▾"
                           Foreground="#5A5A72" FontSize="10"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Popup calendrier custom -->
        <Popup x:Name="Pop" StaysOpen="False" Placement="Bottom"
               PlacementTarget="{Binding ElementName=BdMain}">
            <Border Background="#0D0D0F" BorderBrush="#222228"
                    BorderThickness="1" CornerRadius="2" Padding="6">
                <StackPanel>
                    <!-- Navigation mois -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="26"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnPrev" Grid.Column="0" Content="&#x2039;"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#E8002D" FontSize="18"
                                Cursor="Hand" Click="BtnPrev_Click"/>
                        <TextBlock x:Name="TxtHeader" Grid.Column="1"
                                   Foreground="#E8002D" FontWeight="SemiBold" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button x:Name="BtnNext" Grid.Column="2" Content="&#x203A;"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#E8002D" FontSize="18"
                                Cursor="Hand" Click="BtnNext_Click"/>
                    </Grid>

                    <!-- Grille jours (peuplée en code-behind) -->
                    <Grid x:Name="GrdDays"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
